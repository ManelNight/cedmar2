@prefix : <https://manelnight.github.io/cedmar2/docs/documentation/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://manelnight.github.io/cedmar2/docs/documentation/> .

<https://manelnight.github.io/cedmar2/docs/documentation/> rdf:type owl:Ontology ;
                                                            owl:versionIRI <https://manelnight.github.io/cedmar2/docs/documentation/1.0.0> ;
                                                            <http://purl.org/dc/elements/1.1/contributor> "Colaborador Nombre" ;
                                                            <http://purl.org/dc/elements/1.1/creator> "Manel Bañó Richart" ;
                                                            <http://purl.org/dc/elements/1.1/description> "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                                            <http://purl.org/dc/elements/1.1/publisher> "UOC - Universitat Oberta de Catalunya" ;
                                                            <http://purl.org/dc/elements/1.1/title> "CEDMAR Medical Device Ontology" ;
                                                            <http://purl.org/dc/terms/bibliographicCitation> "Bañó Richart, M. (2026). CEDMAR Medical Device Ontology. Version 1.0."@en ;
                                                            <http://purl.org/dc/terms/created> "2026-04-13"^^xsd:date ;
                                                            <http://purl.org/dc/terms/issued> "2026-04-13"^^xsd:date ;
                                                            <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                            <http://purl.org/dc/terms/modified> "2026-04-13"^^xsd:date ;
                                                            <http://purl.org/dc/terms/source> <https://github.com/ManelNight/cedmar2> ;
                                                            <http://purl.org/ontology/bibo/doi> "10.0000/cedmar.v1" ;
                                                            <http://purl.org/vocab/vann/preferredNamespacePrefix> "cedmar" ;
                                                            <http://purl.org/vocab/vann/preferredNamespaceUri> "https://manelnight.github.io/cedmar2/docs/documentation/#" ;
                                                            rdfs:comment "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                                            rdfs:label "CEDMAR Medical Device Ontology"@en ;
                                                            owl:versionInfo "1.0" ;
                                                            <http://xmlns.com/foaf/0.1/logo> <https://manelnight.github.io/cedmar2/docs/logo.png> .

