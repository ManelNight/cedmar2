#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice
<https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice> rdf:type owl:ObjectProperty ;
                                                                               rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                               rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                               rdfs:comment "Inferred property linking action to device."@en ;
                                                                               rdfs:label "action affects device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk
<https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk> rdf:type owl:ObjectProperty ;
                                                                        rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                        rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                        rdfs:comment "Relates an incident to the specific IMDRF risk that caused it."@en ;
                                                                        rdfs:label "caused by risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#deviceAffectedByAction
<https://manelnight.github.io/cedmar2/docs/documentation/#deviceAffectedByAction> rdf:type owl:ObjectProperty ;
                                                                                  owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice> ;
                                                                                  rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                                  rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                                  rdfs:comment "Relates a device to the corrective action affecting it."@en ;
                                                                                  rdfs:label "device affected by action"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#deviceInvolvedIn
<https://manelnight.github.io/cedmar2/docs/documentation/#deviceInvolvedIn> rdf:type owl:ObjectProperty ;
                                                                            owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice> ;
                                                                            rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                            rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                            rdfs:comment "Relates a device to the incident it is involved in."@en ;
                                                                            rdfs:label "device involved in"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk
<https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk> rdf:type owl:ObjectProperty ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                         rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                         rdfs:comment "Inferred property linking device to risk."@en ;
                                                                         rdfs:label "exposed to risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer
<https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer> rdf:type owl:ObjectProperty ;
                                                                           rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                           rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                           rdfs:comment "Relates a medical device to its manufacturer."@en ;
                                                                           rdfs:label "has manufacturer"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass
<https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass> rdf:type owl:ObjectProperty ;
                                                                        rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                        rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#RiskClass> ;
                                                                        rdfs:comment "Relates a device to its regulatory risk class."@en ;
                                                                        rdfs:label "has risk class"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#incidentResolvedBy
<https://manelnight.github.io/cedmar2/docs/documentation/#incidentResolvedBy> rdf:type owl:ObjectProperty ;
                                                                              owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident> ;
                                                                              rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                              rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                              rdfs:comment "Relates an incident to the corrective action that resolves it."@en ;
                                                                              rdfs:label "incident resolved by"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice
<https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice> rdf:type owl:ObjectProperty ;
                                                                          rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                          rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                          rdfs:comment "Relates an incident to the medical device involved."@en ;
                                                                          rdfs:label "involves device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isLocationOf
<https://manelnight.github.io/cedmar2/docs/documentation/#isLocationOf> rdf:type owl:ObjectProperty ;
                                                                        owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn> ;
                                                                        rdfs:domain <http://dbpedia.org/ontology/Country> ;
                                                                        rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                        rdfs:comment "Relates a country to the manufacturer located there."@en ;
                                                                        rdfs:label "is location of"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturerOf
<https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturerOf> rdf:type owl:ObjectProperty ;
                                                                            owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer> ;
                                                                            rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                            rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                            rdfs:comment "Relates a manufacturer to the device it produces."@en ;
                                                                            rdfs:label "is manufacturer of"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturingLocationOf
<https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturingLocationOf> rdf:type owl:ObjectProperty ;
                                                                                     owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn> ;
                                                                                     rdfs:domain <http://dbpedia.org/ontology/Country> ;
                                                                                     rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                                     rdfs:comment "Relates a country to the device manufactured there."@en ;
                                                                                     rdfs:label "is manufacturing location of"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isRiskClassOf
<https://manelnight.github.io/cedmar2/docs/documentation/#isRiskClassOf> rdf:type owl:ObjectProperty ;
                                                                         owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass> ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#RiskClass> ;
                                                                         rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                         rdfs:comment "Relates a risk class to the device assigned to it."@en ;
                                                                         rdfs:label "is risk class of"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn
<https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                     rdfs:range <http://dbpedia.org/ontology/Country> ;
                                                                     rdfs:comment "Relates a manufacturer to its geographical country."@en ;
                                                                     rdfs:label "located in"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn
<https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn> rdf:type owl:ObjectProperty ;
                                                                          rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                          rdfs:range <http://dbpedia.org/ontology/Country> ;
                                                                          rdfs:comment "Inferred property linking device to country."@en ;
                                                                          rdfs:label "manufactured in"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident
<https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident> rdf:type owl:ObjectProperty ;
                                                                            rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                            rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                            rdfs:comment "Relates a corrective action (FSCA) to the incident it resolves."@en ;
                                                                            rdfs:label "resolves incident"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#riskCausesIncident
<https://manelnight.github.io/cedmar2/docs/documentation/#riskCausesIncident> rdf:type owl:ObjectProperty ;
                                                                              owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk> ;
                                                                              rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                              rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                              rdfs:comment "Relates a risk to the incident it caused."@en ;
                                                                              rdfs:label "risk causes incident"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#riskExposesDevice
<https://manelnight.github.io/cedmar2/docs/documentation/#riskExposesDevice> rdf:type owl:ObjectProperty ;
                                                                             owl:inverseOf <https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk> ;
                                                                             rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                             rdfs:range <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                             rdfs:comment "Relates a risk to the device exposed to it."@en ;
                                                                             rdfs:label "risk exposes device"@en .


#################################################################
#    Data properties
#################################################################

###  https://manelnight.github.io/cedmar2/docs/documentation/#actionTaken
<https://manelnight.github.io/cedmar2/docs/documentation/#actionTaken> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                       rdfs:range xsd:boolean ;
                                                                       rdfs:comment "Was action taken."@en ;
                                                                       rdfs:label "action taken"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#devicesAffected
<https://manelnight.github.io/cedmar2/docs/documentation/#devicesAffected> rdf:type owl:DatatypeProperty ;
                                                                           rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                           rdfs:range xsd:integer ;
                                                                           rdfs:comment "Number of devices affected."@en ;
                                                                           rdfs:label "devices affected"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasAuthority
<https://manelnight.github.io/cedmar2/docs/documentation/#hasAuthority> rdf:type owl:DatatypeProperty ;
                                                                        rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                        rdfs:range xsd:string ;
                                                                        rdfs:comment "Competent authority."@en ;
                                                                        rdfs:label "has authority"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasDescription
<https://manelnight.github.io/cedmar2/docs/documentation/#hasDescription> rdf:type owl:DatatypeProperty ;
                                                                          rdfs:domain owl:Thing ;
                                                                          rdfs:range xsd:string ;
                                                                          rdfs:comment "General description."@en ;
                                                                          rdfs:label "has description"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasDeviceName
<https://manelnight.github.io/cedmar2/docs/documentation/#hasDeviceName> rdf:type owl:DatatypeProperty ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                         rdfs:range xsd:string ;
                                                                         rdfs:comment "Commercial or trade name of the medical device."@en ;
                                                                         rdfs:label "has device name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasEmail
<https://manelnight.github.io/cedmar2/docs/documentation/#hasEmail> rdf:type owl:DatatypeProperty ;
                                                                    rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                    rdfs:range xsd:string ;
                                                                    rdfs:comment "Contact email."@en ;
                                                                    rdfs:label "has email"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasEudamedRef
<https://manelnight.github.io/cedmar2/docs/documentation/#hasEudamedRef> rdf:type owl:DatatypeProperty ;
                                                                         rdfs:domain owl:Thing ;
                                                                         rdfs:range xsd:anyURI ;
                                                                         rdfs:comment "EUDAMED URL reference."@en ;
                                                                         rdfs:label "has Eudamed ref"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasFramework
<https://manelnight.github.io/cedmar2/docs/documentation/#hasFramework> rdf:type owl:DatatypeProperty ;
                                                                        rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                        rdfs:range xsd:string ;
                                                                        rdfs:comment "Regulatory framework MDR/IVDR."@en ;
                                                                        rdfs:label "has framework"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasGeoScope
<https://manelnight.github.io/cedmar2/docs/documentation/#hasGeoScope> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction> ;
                                                                       rdfs:range xsd:string ;
                                                                       rdfs:comment "Regions or countries affected by a corrective action."@en ;
                                                                       rdfs:label "has geo scope"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasLegalName
<https://manelnight.github.io/cedmar2/docs/documentation/#hasLegalName> rdf:type owl:DatatypeProperty ;
                                                                        rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                        rdfs:range xsd:string ;
                                                                        rdfs:comment "Official legal name."@en ;
                                                                        rdfs:label "has legal name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasOutcome
<https://manelnight.github.io/cedmar2/docs/documentation/#hasOutcome> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                      rdfs:range xsd:string ;
                                                                      rdfs:comment "Clinical outcome."@en ;
                                                                      rdfs:label "has outcome"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientAge
<https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientAge> rdf:type owl:DatatypeProperty ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                         rdfs:range xsd:integer ;
                                                                         rdfs:comment "Age of patient."@en ;
                                                                         rdfs:label "has patient age"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientSex
<https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientSex> rdf:type owl:DatatypeProperty ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                         rdfs:range xsd:string ;
                                                                         rdfs:comment "Sex of patient."@en ;
                                                                         rdfs:label "has patient sex"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPriority
<https://manelnight.github.io/cedmar2/docs/documentation/#hasPriority> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                       rdfs:range xsd:string ;
                                                                       rdfs:comment "Priority of ocurrence"@en ;
                                                                       rdfs:label "Has Priority"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasProbability
<https://manelnight.github.io/cedmar2/docs/documentation/#hasProbability> rdf:type owl:DatatypeProperty ;
                                                                          rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                          rdfs:range xsd:string ;
                                                                          rdfs:comment "Probability of occurrence."@en ;
                                                                          rdfs:label "has probability"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPurpose
<https://manelnight.github.io/cedmar2/docs/documentation/#hasPurpose> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Device> ;
                                                                      rdfs:range xsd:string ;
                                                                      rdfs:comment "Intended purpose."@en ;
                                                                      rdfs:label "has purpose"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasReportDate
<https://manelnight.github.io/cedmar2/docs/documentation/#hasReportDate> rdf:type owl:DatatypeProperty ;
                                                                         rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Incident> ;
                                                                         rdfs:range xsd:dateTime ;
                                                                         rdfs:comment "Date of report."@en ;
                                                                         rdfs:label "has report date"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskName
<https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskName> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                       rdfs:range xsd:string ;
                                                                       rdfs:comment "Name of the risk."@en ;
                                                                       rdfs:label "has risk name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasSRN
<https://manelnight.github.io/cedmar2/docs/documentation/#hasSRN> rdf:type owl:DatatypeProperty ;
                                                                  rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer> ;
                                                                  rdfs:range xsd:string ;
                                                                  rdfs:comment "Single Registration Number."@en ;
                                                                  rdfs:label "has SRN"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasSeverity
<https://manelnight.github.io/cedmar2/docs/documentation/#hasSeverity> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:domain <https://manelnight.github.io/cedmar2/docs/documentation/#Risk> ;
                                                                       rdfs:range xsd:string ;
                                                                       rdfs:comment "Severity level."@en ;
                                                                       rdfs:label "has severity"@en .


