    <owl:Class rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
