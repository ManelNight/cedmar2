                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Instrument intended for medical purposes.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
    </owl:Class>
    


