    <rdf:Description rdf:about="https://manelnight.github.io/CEDMAR/docs/documentation#d">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://manelnight.github.io/CEDMAR/docs/documentation#m">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://manelnight.github.io/CEDMAR/docs/documentation#c">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://manelnight.github.io/CEDMAR/docs/documentation#i">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://manelnight.github.io/CEDMAR/docs/documentation#r">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Infers the manufacturing country of a device based on its manufacturer.</rdfs:comment>
        <rdfs:label>Rule3_ManufacturedIn</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn"/>
                                <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#m"/>
                                <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#c"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer"/>
                                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                                        <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#m"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn"/>
                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                        <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#c"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Infers which devices are affected by a corrective action.</rdfs:comment>
        <rdfs:label>Rule2_ActionAffects</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident"/>
                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#c"/>
                        <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#i"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice"/>
                                <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#i"/>
                                <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
                                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#c"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice"/>
                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#c"/>
                        <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Infers the risk a device is exposed to based on its incidents.</rdfs:comment>
        <rdfs:label>Rule1_ExposedToRisk</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk"/>
                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#i"/>
                        <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#r"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice"/>
                                <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#i"/>
                                <swrl:argument2 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                        <swrl:classPredicate rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
                                        <swrl:argument1 rdf:resource="https://manelnight.github.io/CEDMAR/docs/documentation#i"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
