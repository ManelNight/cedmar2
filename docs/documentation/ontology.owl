<?xml version="1.0"?>
<rdf:RDF xmlns="https://manelnight.github.io/cedmar2/docs/documentation/"
     xml:base="https://manelnight.github.io/cedmar2/docs/documentation/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:bibo="http://purl.org/ontology/bibo/"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:documentation="https://manelnight.github.io/cedmar2/docs/documentation/#">
    <owl:Ontology rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/">
        <owl:versionIRI rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/1.0.0"/>
        <dc:contributor>Colaborador Nombre</dc:contributor>
        <dc:creator>Manel Bañó Richart</dc:creator>
        <dc:description xml:lang="en">Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR).</dc:description>
        <dc:publisher>UOC - Universitat Oberta de Catalunya</dc:publisher>
        <dc:title>CEDMAR Medical Device Ontology</dc:title>
        <terms:bibliographicCitation xml:lang="en">Bañó Richart, M. (2026). CEDMAR Medical Device Ontology. Version 1.0.</terms:bibliographicCitation>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-13</terms:created>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-13</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-13</terms:modified>
        <terms:source rdf:resource="https://github.com/ManelNight/cedmar2"/>
        <bibo:doi>10.0000/cedmar.v1</bibo:doi>
        <vann:preferredNamespacePrefix>cedmar</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://manelnight.github.io/cedmar2/docs/documentation/#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">CEDMAR Medical Device Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
        <foaf:logo rdf:resource="https://manelnight.github.io/cedmar2/docs/logo.png"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributor"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/publisher"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/source -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/ontology/bibo/doi -->


    <owl:AnnotationProperty rdf:about="http://purl.org/ontology/bibo/doi"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- http://xmlns.com/foaf/0.1/logo -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/logo"/>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasDetectDate -->


    <owl:AnnotationProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasDetectDate"/>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasEventDate -->


    <owl:AnnotationProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasEventDate"/>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasStartDate -->


    <owl:AnnotationProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasStartDate"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Inferred property linking action to device.</rdfs:comment>
        <rdfs:label xml:lang="en">action affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the specific IMDRF risk that caused it.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#deviceAffectedByAction -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#deviceAffectedByAction">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Relates a device to the corrective action affecting it.</rdfs:comment>
        <rdfs:label xml:lang="en">device affected by action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#deviceInvolvedIn -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#deviceInvolvedIn">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:comment xml:lang="en">Relates a device to the incident it is involved in.</rdfs:comment>
        <rdfs:label xml:lang="en">device involved in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Risk"/>
        <rdfs:comment xml:lang="en">Inferred property linking device to risk.</rdfs:comment>
        <rdfs:label xml:lang="en">exposed to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#incidentResolvedBy -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#incidentResolvedBy">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Relates an incident to the corrective action that resolves it.</rdfs:comment>
        <rdfs:label xml:lang="en">incident resolved by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the medical device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#isLocationOf -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#isLocationOf">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn"/>
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a country to the manufacturer located there.</rdfs:comment>
        <rdfs:label xml:lang="en">is location of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturerOf -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturerOf">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to the device it produces.</rdfs:comment>
        <rdfs:label xml:lang="en">is manufacturer of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturingLocationOf -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturingLocationOf">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn"/>
        <rdfs:domain rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Relates a country to the device manufactured there.</rdfs:comment>
        <rdfs:label xml:lang="en">is manufacturing location of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#isRiskClassOf -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#isRiskClassOf">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#RiskClass"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Relates a risk class to the device assigned to it.</rdfs:comment>
        <rdfs:label xml:lang="en">is risk class of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to its geographical country.</rdfs:comment>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:comment xml:lang="en">Inferred property linking device to country.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactured in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:comment xml:lang="en">Relates a corrective action (FSCA) to the incident it resolves.</rdfs:comment>
        <rdfs:label xml:lang="en">resolves incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#riskCausesIncident -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#riskCausesIncident">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Risk"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:comment xml:lang="en">Relates a risk to the incident it caused.</rdfs:comment>
        <rdfs:label xml:lang="en">risk causes incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#riskExposesDevice -->


    <owl:ObjectProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#riskExposesDevice">
        <owl:inverseOf rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk"/>
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Risk"/>
        <rdfs:range rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:comment xml:lang="en">Relates a risk to the device exposed to it.</rdfs:comment>
        <rdfs:label xml:lang="en">risk exposes device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#actionTaken -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#actionTaken">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Was action taken.</rdfs:comment>
        <rdfs:label xml:lang="en">action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#devicesAffected -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#devicesAffected">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of devices affected.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasAuthority -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasAuthority">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">has authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasDescription -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasDescription">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">General description.</rdfs:comment>
        <rdfs:label xml:lang="en">has description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasDeviceName">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial or trade name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasEmail -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasEmail">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contact email.</rdfs:comment>
        <rdfs:label xml:lang="en">has email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasEudamedRef -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasEudamedRef">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">EUDAMED URL reference.</rdfs:comment>
        <rdfs:label xml:lang="en">has Eudamed ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasFramework -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasFramework">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Regulatory framework MDR/IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">has framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasGeoScope -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasGeoScope">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Regions or countries affected by a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has geo scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasLegalName -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasLegalName">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Official legal name.</rdfs:comment>
        <rdfs:label xml:lang="en">has legal name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://manelnight.github.io/cedmar2/docs/documentation/#hasOutcome -->


    <owl:DatatypeProperty rdf:about="https://manelnight.github.io/cedmar2/docs/documentation/#hasOutcome">
        <rdfs:domain rdf:resource="https://manelnight.github.io/cedmar2/docs/documentation/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Clinical outcome.</rdfs:comment>
        <rdfs:label xml:lang="en">has outcome</rdfs:label>
